---
import { githubUrl, linkedinUrl } from "../consts";
const today = new Date();
---

<footer class="pt-8 pb-16 px-4 text-center  to-transparent">
	&copy; {today.getFullYear()} Yatraj.dev . All rights reserved.

	<div class="flex justify-center gap-4 mt-4">

		<a
			href={linkedinUrl}
			target="_blank"
			class="text-white hover:text-gray-500 transition-colors"
		>
			<span class="sr-only">LinkedIn Profile</span>
			<svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor">
				<path d="M4.98 3.5C4.98 4.88 3.88 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5zM.5 8h4V24h-4zM8.5 8h3.8v2.2h.1c.5-1 1.8-2.2 3.7-2.2 4 0 4.7 2.6 4.7 6V24h-4v-7.8c0-1.9 0-4.3-2.6-4.3s-3 2-3 4.2V24h-4z"/>
			</svg>
		</a>

		<a
			href={githubUrl}
			target="_blank"
			class="text-white hover:text-gray-500 transition-colors"
		>
			<span class="sr-only">GitHub Profile</span>
			<svg viewBox="0 0 16 16" width="32" height="32" fill="currentColor">
				<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
			</svg>
		</a>

	</div>
</footer>